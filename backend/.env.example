# ============================================================
# DelphiGraph Causal Engine - 环境变量配置
# 复制为 .env 并填入实际值
# ============================================================

# 千问 LLM（DashScope）
# 获取地址: https://dashscope.aliyuncs.com
DASHSCOPE_API_KEY=

# 可选: 使用其他兼容 OpenAI 的模型
# QWEN_API_KEY=sk-...

# Supabase（注意: 变量名是 SUPABASE_URL，不是 NEXT_PUBLIC_SUPABASE_URL）
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 引擎配置（可选，有默认值）
CAUSAL_ENGINE_PORT=8100         # 默认端口
CAUSAL_POLL_INTERVAL=30         # 自动轮询间隔（秒）
CAUSAL_MIN_SIGNALS=5            # 触发分析的最低预测数
CAUSAL_MIN_SIGNALS_FINAL=20     # 标记为最终分析的预测数阈值
CAUSAL_ENGINE_RELOAD=false      # 开发模式热重载

# Survey Engine 已与 Causal Engine 合并，共用 CAUSAL_ENGINE_PORT，无需额外端口
